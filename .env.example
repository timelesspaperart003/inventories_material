# Notion Integration Token
# 到 https://www.notion.so/my-integrations 建立一個 integration 後取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4 個 Notion Database ID
# 打開 Notion 資料庫頁面，URL 中 notion.so/ 後面那段 32 字元就是 Database ID
# 例: https://www.notion.so/myworkspace/abc123def456...?v=... → abc123def456...

NOTION_DB_MATERIAL=你的材料資料庫ID
NOTION_DB_CRAFT=你的代工_植物_動物資料庫ID
NOTION_DB_CONSUMABLE=你的耗材資料庫ID
NOTION_DB_PALLET=你的棧板材料_自黏袋資料庫ID
